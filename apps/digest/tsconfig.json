{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "types": ["bun"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
